{
  "version": 2,
  "description": "Pillar invocation patterns for scripts/audit-pillars.sh (L-012 closure). Each pillar lists regex patterns matched against the slice's commit messages + diff. A pillar is INVOKED iff at least one pattern matches and no negative_pattern matches the same context. v2 (SPEC_V02G AC-6) adds an optional per-pillar `skills` array — purely informational metadata for the gStack pillar that names the individual skills v0.2.g now wraps (ship, qa, cso, document-release). The script is backward compatible: it accepts both version 1 and version 2 (the `skills` field is ignored by the count logic — additive change).",
  "pillars": [
    {
      "name": "Spec Kit",
      "patterns": [
        "\\.specify/memory/",
        "spec[ -_]kit",
        "Spec Kit"
      ],
      "negative_patterns": []
    },
    {
      "name": "OpenSpec",
      "patterns": [
        "openspec/",
        "OpenSpec",
        "open[ -_]spec"
      ],
      "negative_patterns": []
    },
    {
      "name": "BMAD",
      "patterns": [
        "_bmad/",
        "_bmad-output/",
        "/bmad-adv-auto-dev",
        "bmad-method",
        "BMAD",
        "auto-dev"
      ],
      "negative_patterns": []
    },
    {
      "name": "gStack",
      "patterns": [
        "~/\\.claude/skills/gstack/",
        "\\.claude/skills/gstack",
        "/ship\\b",
        "/qa\\b",
        "/cso\\b",
        "/document-release",
        "/context-save",
        "gstack-config",
        "mmd ship",
        "mmd qa",
        "mmd cso",
        "mmd document-release",
        "gStack"
      ],
      "negative_patterns": [],
      "skills": [
        { "name": "ship",             "introduced": "v0.2.f", "wrapper": "bin/skills/ship.js" },
        { "name": "qa",               "introduced": "v0.2.g", "wrapper": "bin/skills/qa.js" },
        { "name": "cso",              "introduced": "v0.2.g", "wrapper": "bin/skills/cso.js" },
        { "name": "document-release", "introduced": "v0.2.g", "wrapper": "bin/skills/document-release.js" }
      ]
    },
    {
      "name": "Ralph Loop",
      "patterns": [
        "ralph[ -_]loop",
        "Ralph Loop",
        "bounded loop"
      ],
      "negative_patterns": []
    }
  ]
}
