# BMAD install (generated by install-mmd.sh, kept out per existing convention)
_bmad/

# Claude Code project-scoped commands and skill mirrors (generated by install-mmd.sh
# and by BMAD itself: 1058 files / 14 MB of regenerable artifacts). New devs run
# `bash install-mmd.sh .` after clone to recreate them. Keep out of git.
.claude/

# BMAD outputs (planning + implementation artifacts, generated per run)
_bmad-output/

# BMAD bmb/tea modules output dir (their convention — collides naming-wise with gStack
# but lives under repo root, separate from ~/.claude/skills/).
# Anchored at the root with a leading slash to avoid swallowing
# `bin/skills/`, `lib/skills/`, `test/integration/skills*` (v0.2.g additions).
/skills/

